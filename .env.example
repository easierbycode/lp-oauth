# TikTok OAuth credentials from https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Optional — defaults to http://localhost:8000
# Must match the Redirect URI configured in the TikTok app.
# `deno task dev:tunnel` rewrites this automatically with the ngrok URL.
# BASE_URL=http://localhost:8000

# Optional — used by `deno task dev:tunnel` to request a stable ngrok URL
# (paid ngrok feature). Leave unset to get a random URL each run.
# NGROK_DOMAIN=your-reserved.ngrok-free.app
